# docker
## used by compose files
SERVER_PORT=4000
CLIENT_PORT=5173
TZ=UTC

## used only by compose.prod.shared.yaml
SHARED_NETWORK=shared_net

# server
## required in all modes
NODE_ENV=development
JWT_SECRET=replace_with_long_secure_secret_min_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=replace_with_another_long_secure_secret_min_32_chars
JWT_REFRESH_EXPIRES_IN=7d

## optional in all modes (server has defaults in zod)
CORS_ORIGIN=http://localhost:5173
SOCKET_CORS_ORIGIN=http://localhost:5173
REFRESH_COOKIE_NAME=quizpop_refresh_token
CSRF_COOKIE_NAME=quizpop_csrf_token
# Use COOKIE_SAME_SITE=none and COOKIE_SECURE=true when the client and API are on different domains.
# For subdomain deployments, set COOKIE_DOMAIN to the shared parent domain, such as .example.com.
COOKIE_SECURE=false
COOKIE_SAME_SITE=strict
COOKIE_DOMAIN=
SERVER_PUBLIC_BASE_URL=http://localhost:4000

MINIO_PORT=9000
MINIO_REGION=local-1
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=replace_with_secure_minio_password
MINIO_BUCKET=avatars
MINIO_AVATARS_BUCKET=avatars
MINIO_PUBLIC_BASE_URL=http://localhost:9000

REDIS_USER=default
REDIS_KEY_PREFIX=quizpop:
REDIS_CACHE_TTL_SECONDS=60
CACHE_TTL_QUESTION_POOL_SECONDS=600
CACHE_TTL_QUESTION_POOL_STALE_SECONDS=1800
CACHE_TTL_LEADERBOARD_SECONDS=45
CACHE_TTL_LEADERBOARD_STALE_SECONDS=180
CACHE_TTL_USER_PROFILE_SECONDS=300
CACHE_TTL_USER_PROFILE_STALE_SECONDS=900

API_RATE_LIMIT_WINDOW_MS=900000
API_RATE_LIMIT_MAX=600
AUTH_REGISTER_RATE_LIMIT_WINDOW_MS=900000
AUTH_REGISTER_RATE_LIMIT_MAX=10
AUTH_LOGIN_RATE_LIMIT_WINDOW_MS=900000
AUTH_LOGIN_RATE_LIMIT_MAX=6
AUTH_TOKEN_RATE_LIMIT_WINDOW_MS=900000
AUTH_TOKEN_RATE_LIMIT_MAX=40
SENSITIVE_WRITE_RATE_LIMIT_WINDOW_MS=600000
SENSITIVE_WRITE_RATE_LIMIT_MAX=120

QUIZ_DEFAULT_QUESTION_LIMIT=10
QUIZ_MAX_QUESTION_LIMIT=50
SOLO_QUESTION_TIME_LIMIT_MS=15000
ROOM_QUESTION_TIME_LIMIT_MS=25000
ROOM_RACE_END_BUFFER_MS=15000
ROOM_QUESTION_COUNT=10
ROOM_MAX_PLAYERS=20
LEADERBOARD_MIN_GAMES_FOR_RANKING=5
LEADERBOARD_MAX_PAGE_LIMIT=100

## fill these for compose.dev.yaml and compose.prod.yaml
POSTGRES_DB=quizpop_dev
POSTGRES_USER=quizpop_user
POSTGRES_PASSWORD=replace_with_secure_password
POSTGRES_PORT=5432

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=replace_with_secure_minio_password
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

REDIS_PASSWORD=replace_with_secure_redis_password
REDIS_PORT=6379

## fill these for compose.prod.shared.yaml
## use values from your Manage Shared Projects generated env file
DATABASE_URL=postgresql://user:password@shared_postgres:5432/db
REDIS_URL=redis://user:password@shared_redis:6379
MINIO_ENDPOINT=shared_minio:9000
MINIO_ACCESS_KEY=shared_user
MINIO_SECRET_KEY=shared_secret

## optional when REDIS_URL is set (server falls back to URL)
REDIS_HOST=shared_redis

# client
## used by client dev and client prod build
VITE_API_BASE_URL=http://server:4000/api
VITE_SOCKET_URL=http://server:4000

## optional in client (client has fallback defaults)
VITE_CSRF_COOKIE_NAME=quizpop_csrf_token
VITE_API_REQUEST_TIMEOUT_MS=20000
VITE_TOAST_DURATION_MS=3600
VITE_DEFAULT_QUESTION_LIMIT=10
VITE_QUIZ_QUESTION_TIME_LIMIT_MS=30000
VITE_ROOM_QUESTION_TIME_LIMIT_MS=25000
