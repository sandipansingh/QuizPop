{
  "name": "@quizpop/server",
  "version": "1.0.0",
  "private": true,
  "description": "QuizPop - Node.js/Express backend API with real-time multiplayer support",
  "main": "src/app/server.js",
  "type": "module",
  "author": "sandipansingh",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "keywords": [
    "express",
    "nodejs",
    "api",
    "websocket",
    "socket.io",
    "quiz",
    "postgresql",
    "prisma",
    "redis",
    "backend"
  ],
  "scripts": {
    "dev": "nodemon src/app/server.js",
    "build": "npm run lint",
    "start": "node src/app/server.js",
    "lint": "eslint src prisma",
    "lint:fix": "eslint src prisma --fix",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:deploy-or-push": "node scripts/prepare-database.js",
    "prisma:seed": "node prisma/seed.js",
    "test": "echo \"Tests to be configured\""
  },
  "dependencies": {
    "@prisma/client": "^6.19.2",
    "@scalar/express-api-reference": "^0.9.9",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "minio": "^8.0.7",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "rate-limit-redis": "^4.2.2",
    "redis": "^5.8.3",
    "sanitizer": "^0.1.3",
    "socket.io": "^4.8.3",
    "validator": "^13.15.35",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^16.5.0",
    "nodemon": "^3.1.14",
    "prisma": "^6.19.2",
    "prettier": "^3.8.3"
  }
}
