FROM node:22-alpine AS base

WORKDIR /app

COPY package*.json ./
COPY apps/client/package*.json ./apps/client/

RUN npm ci --workspace apps/client --include-workspace-root=false

COPY apps/client ./apps/client

FROM base AS development

WORKDIR /app/apps/client

EXPOSE 5173

CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0", "--port", "5173"]

FROM base AS builder

WORKDIR /app/apps/client

ARG VITE_API_BASE_URL
ARG VITE_SOCKET_URL
ARG VITE_CSRF_COOKIE_NAME
ARG VITE_API_REQUEST_TIMEOUT_MS
ARG VITE_TOAST_DURATION_MS
ARG VITE_DEFAULT_QUESTION_LIMIT
ARG VITE_QUIZ_QUESTION_TIME_LIMIT_MS
ARG VITE_ROOM_QUESTION_TIME_LIMIT_MS

ENV VITE_API_BASE_URL=$VITE_API_BASE_URL
ENV VITE_SOCKET_URL=$VITE_SOCKET_URL
ENV VITE_CSRF_COOKIE_NAME=$VITE_CSRF_COOKIE_NAME
ENV VITE_API_REQUEST_TIMEOUT_MS=$VITE_API_REQUEST_TIMEOUT_MS
ENV VITE_TOAST_DURATION_MS=$VITE_TOAST_DURATION_MS
ENV VITE_DEFAULT_QUESTION_LIMIT=$VITE_DEFAULT_QUESTION_LIMIT
ENV VITE_QUIZ_QUESTION_TIME_LIMIT_MS=$VITE_QUIZ_QUESTION_TIME_LIMIT_MS
ENV VITE_ROOM_QUESTION_TIME_LIMIT_MS=$VITE_ROOM_QUESTION_TIME_LIMIT_MS

RUN npm run build

FROM nginx:1.29-alpine AS production

COPY apps/client/nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=builder /app/apps/client/dist /usr/share/nginx/html

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
